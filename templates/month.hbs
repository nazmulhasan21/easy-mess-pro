<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta http-equiv='X-UA-Compatible' content='IE=edge' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}}</title>
    <link
      href='https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css'
      rel='stylesheet'
      integrity='sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC'
      crossorigin='anonymous'
    />

  </head>
  <body>
    <div class='container-fluid'>
      <h1 class='text-center'>{{messId.messName}}</h1>
      <h5 class='text-center'>Manager
        <img
          src='{{manager.avatar}}'
          width='30'
          height='30'
        />{{manager.name}}</h5>

      <h6 class='text-center'>Month Title:{{monthTitle}}</h6>
      <h6 class='text-center'>Rice Balance:{{riceBalance}}</h6>
      <h6 class='text-center'>MealRate:{{mealRate}}</h6>
      <div class='row'>
        <div class='p-4'>
          <table class='table table-bordered table-striped'>
            <thead>
              <tr class='px-1 m-0'>
                <th class='px-1 m-0'>নাম</th>
                <th class='px-1 m-0'>মিল</th>
                <th class='px-1 m-0'>ফি: মিল</th>
                <th class='px-1 m-0'>ফি: মি:খরচ</th>
                <th class='px-1 m-0'>অন্যান্য খরচ</th>
                <th class='px-1 m-0'>মোট খরচ</th>
                <th class='px-1 m-0'>জমা</th>
                <th class='px-1 m-0'>উদ্বৃত্ত</th>
                <th class='px-1 m-0'>চাউল উদ্বৃত্ত</th>
              </tr>
            </thead>
            <tbody class='px-1 m-0'>
              {{#each userMonthData as |member|}}
                <tr>
                  <td class='px-1 m-0'><img
                      src='{{member.userId.avatar}}'
                      width='30'
                      height='30'
                    />{{member.userId.name}}</td>
                  <td class='px-1 m-0'>{{member.totalMeal}}</td>
                  <td class='px-1 m-0'>{{member.fixedMeal}}</td>
                  <td class='px-1 m-0'>{{member.mealCost}}</td>
                  <td class='px-1 m-0'>{{member.otherCost}}</td>
                  <td class='px-1 m-0'>{{member.totalCost}}</td>
                  <td class='px-1 m-0'>{{member.totalDeposit}}</td>
                  <td class='px-1 m-0'>{{member.balance}}</td>
                  <td class='px-1 m-0'>{{member.riceBalance}}</td>
                </tr>
              {{/each}}
            </tbody>
            <thead>
              <tr>
                <th class='px-1 m-0'>Total Border =
                  {{userMonthData.length}}</th>
                <th class='px-1 m-0'>{{totalMeal}}</th>
                <th class='px-1 m-0'>{{totalFixedMeal}}</th>
                <th class='px-1 m-0'>{{totalMealCost}}</th>
                <th class='px-1 m-0'>{{totalOtherCost}}</th>
                <th class='px-1 m-0'>{{totalCost}}</th>
                <th class='px-1 m-0'>{{totalDeposit}}</th>
                <th class='px-1 m-0'>{{balance}}</th>
                <th class='px-1 m-0'>{{riceBalance}}</th>

              </tr>
            </thead>
          </table>
        </div>
      </div>

      {{! rice table }}

      <div class='row'>

        {{! cost table }}

        <div class='p-4'>
          <h6 class='text-center'> সকল বডারের তথ্য</h6>
          <table class='table table-bordered table-striped'>
            <thead class='px-1 m-0'>
              <tr>
                <th>নাম</th>
                <th> টাকা জমা</th>
                <th> চাউল জমা</th>
                <th> অতিরিক্ত চাউল</th>
                <th>অতিথি মিলের টাকা</th>

              </tr>
            </thead>
            <tbody class='px-1 m-0'>
              {{#each monthMemberData}}
                <tr>
                  <td class='px-0 m-0'><img
                      src='{{avatar}}'
                      width='30'
                      height='30'
                    />{{name}}</td>

                  <td>{{cashTotal}}</td>
                  <td>{{riceTotal}}</td>
                  <td>{{extraRiceTotal}}</td>
                  <td>{{guestMealTotal}}</td>

                </tr>
              {{/each}}
            </tbody>
            {{!-- <thead><th>total</th><th>{{total}}</thead> --}}
          </table>

          {{! cost table }}
        </div>

      </div>

      <div class='row'>

        {{! cost table }}
        {{#each costs}}
          <div class='col-6'>
            <h6 class='text-center'>{{title}}</h6>
            <table class='table table-bordered table-striped'>
              <thead>
                <tr>
                  <th>Title</th>
                  <th>amount</th>
                  <th>date</th>
                </tr>
              </thead>
              <tbody>
                {{#data}}
                  <tr>
                    <td>{{title}}</td>
                    <td>{{amount}}</td>
                    <td>{{dateFormat date}}</td>
                  </tr>
                {{/data}}
              </tbody>
              <thead><tr><th>total</th><th>{{total}}</th><th></th></tr></thead>
            </table>

            {{! cost table }}
          </div>
        {{/each}}

        <div class='col-6'>
          <h6 class='text-center'>চলতি মাসের হিসাব</h6>
          <table class='table table-striped'>
            <thead>
              <tr>
                <th>Title</th>
                <th>amount</th>
              </tr>
            </thead>
            <tbody>
              {{#each meals}}
                <tr>
                  <td>{{title}}</td>
                  <td class='text-right'>{{mark}} {{amount}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>

        </div>
      </div>
      {{! meal table }}
      {{!-- <h6 class='text-center'>meal Table</h6>
    {{!  <table class='table table-bordered table-striped'>
        <thead>
          <tr>
            <th>Name</th>
            <th>breakfast</th>
            <th>lunch</th>
            <th>dinner</th>
            <th>total</th>
            <th>date</th>

          </tr>
        </thead>
        <tbody>

          {{#each meals as |meal|}}
            <tr>
              <td>{{meal.userId.name}}</td>
              <td>{{meal.breakfast}}</td>
              <td>{{meal.lunch}}</td>
              <td>{{meal.dinner}}</td>
              <td>{{meal.total}}</td>
              <td>{{dateFormat meal.date}}</td>
              {{!-- <td>{{cash.date.substring(0,15)}}</td> --}}

      {{!      </tr>
          {{/each}}
      {{! </tbody> }}

      {{! </table> }}
      {{! meal table }}
    </div>
  </body>
</html>